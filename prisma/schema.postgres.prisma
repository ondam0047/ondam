// 바로일지 — 데이터 스키마 (PostgreSQL, 운영용)
// Prisma 7. 로컬은 prisma/schema.prisma (SQLite).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── 멀티 센터 ──────────────────────────────────────────────────────────

model Center {
  id            Int      @id @default(autoincrement())
  name          String
  approvalCode  String   @unique
  address       String?
  phone         String?
  serviceTypes  String   @default("언어재활,놀이치료,감각통합치료")
  slots         String   @default("09:00~09:50,09:50~10:40,10:40~11:30,11:30~12:20,13:30~14:20,14:20~15:10,15:10~16:00,16:00~16:50,16:50~17:40,17:40~18:30,18:30~19:20")
  defaultUnit   Int      @default(60000)
  recordForm    String   @default("standard")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         User[]
  therapists    Therapist[]
  children      Child[]
  invitations   Invitation[]
}

model Invitation {
  id          Int       @id @default(autoincrement())
  token       String    @unique
  centerId    Int
  center      Center    @relation(fields: [centerId], references: [id], onDelete: Cascade)
  role        String
  name        String?
  email       String?
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  createdById Int?

  @@index([centerId])
}

// ─── 권한·로그인 ─────────────────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  passwordHash String
  role         String
  active       Boolean  @default(true)
  therapistType String?
  plan         String   @default("trial")
  trialEndsAt  DateTime?
  betaLockIn   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  centerId     Int?
  center       Center?  @relation(fields: [centerId], references: [id])

  therapistId  Int?     @unique
  therapist    Therapist? @relation(fields: [therapistId], references: [id])

  sessions     AuthSession[]
  schedules    Schedule[] @relation("ScheduleCreatedBy")
  records      Record[]   @relation("RecordCreatedBy")
  passwordResets PasswordReset[]
  recordForms    RecordForm[]
}

model PasswordReset {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model AuthSession {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── 도메인 ────────────────────────────────────────────────────────────

model Therapist {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  centerId  Int?
  center    Center?  @relation(fields: [centerId], references: [id])

  services  ChildService[]
  user      User?
  blocks    TherapistBlock[]
}

model TherapistBlock {
  id          Int      @id @default(autoincrement())
  therapistId Int
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  dayOfWeek   Int
  startTime   String
  endTime     String
  reason      String?
  createdAt   DateTime @default(now())

  @@index([therapistId])
}

model Child {
  id         Int       @id @default(autoincrement())
  name       String
  birthDate  String?
  mgmtNumber String?
  memo       String?
  active     Boolean   @default(true)
  waiting    Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  centerId   Int?
  center     Center?   @relation(fields: [centerId], references: [id])

  services   ChildService[]
  toolSessions ToolSession[]
}

// 바로툴(음성·학습 모듈) 대상자별 측정 세션 — 지속 모니터링용.
model ToolSession {
  id          Int      @id @default(autoincrement())
  childId     Int
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  centerId    Int?
  therapistId Int?
  module      String   // 모듈 키: loudness|spectrogram|mpt|speech-rate|fluency|pacing
  metrics     String   // 요약 지표 JSON
  note        String?
  createdAt   DateTime @default(now())

  @@index([childId, module])
  @@index([centerId])
}

// 업로드한 센터 기록지/일정표 양식 — 프리랜서는 센터마다 달라 사용자별 다수 저장.
model RecordForm {
  id          Int      @id @default(autoincrement())
  ownerUserId Int
  ownerUser   User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  kind        String   // "record"(기록지) | "schedule"(일정표)
  name        String
  template    Bytes    // 업로드한 빈 .hwpx 원본
  spec        String   // 자동매핑 + 보정 결과(JSON)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerUserId, kind])
}

model ChildService {
  id            Int       @id @default(autoincrement())
  childId       Int
  child         Child     @relation(fields: [childId], references: [id], onDelete: Cascade)

  therapistId   Int?
  therapist     Therapist? @relation(fields: [therapistId], references: [id])

  serviceType   String
  defaultSlot   String?
  defaultDays   String?
  daySlots      String?
  org           String?
  defaultUnit   Int       @default(65000)
  defaultTarget Int       @default(5)
  monthlyCopay  Int?

  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  schedules     Schedule[]
  records       Record[]

  @@index([childId])
  @@index([therapistId])
}

model Schedule {
  id             Int      @id @default(autoincrement())
  childServiceId Int
  childService   ChildService @relation(fields: [childServiceId], references: [id], onDelete: Cascade)
  year           Int
  month          Int
  therapist      String
  serviceType    String
  target         Int
  mgmtNumber     String?
  pvOrg          String
  pvTel          String?
  pvCharge       String?
  pvType         String
  costUnit       String
  costSelf       String
  writeDate      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdById    Int?
  createdBy      User?    @relation("ScheduleCreatedBy", fields: [createdById], references: [id])

  sessions       ScheduleSession[]

  @@unique([childServiceId, year, month])
}

model ScheduleSession {
  id         Int      @id @default(autoincrement())
  scheduleId Int
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  day        Int
  time       String
  makeup     Boolean  @default(false)

  @@unique([scheduleId, day])
}

model Record {
  id             Int      @id @default(autoincrement())
  childServiceId Int
  childService   ChildService @relation(fields: [childServiceId], references: [id], onDelete: Cascade)
  year           Int
  month          Int
  org            String
  childName      String
  childBirth     String?
  opinion        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdById    Int?
  createdBy      User?    @relation("RecordCreatedBy", fields: [createdById], references: [id])

  sessions       RecordSession[]

  @@unique([childServiceId, year, month])
}

model RecordSession {
  id          Int      @id @default(autoincrement())
  recordId    Int
  record      Record   @relation(fields: [recordId], references: [id], onDelete: Cascade)
  ordinal     Int
  date        String?
  startTime   String?
  endTime     String?
  voucher     String?
  extra       String?
  amount      String?
  useDay      String?
  payDay      String?
  apprNumber  String?
  result      String?
  resultExtra String?
  status      String?

  @@unique([recordId, ordinal])
}
