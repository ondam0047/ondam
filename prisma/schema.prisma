// 온담말언어발달센터 통합관리 — 데이터 스키마
// SQLite (개발/소규모 운영용) — Prisma 7

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── 멀티 센터 ──────────────────────────────────────────────────────────
// 여러 발달재활센터가 같은 시스템을 공유. 모든 데이터는 Center 단위로 격리.

model Center {
  id            Int      @id @default(autoincrement())
  name          String
  approvalCode  String   @unique // 6자리 영숫자. 치료사 가입 시 입력
  address       String?
  phone         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         User[]
  therapists    Therapist[]
  children      Child[]
}

// ─── 권한·로그인 ─────────────────────────────────────────────────────────
// 역할: OWNER(원장) / ADMIN(행정) / THERAPIST(치료사)
// 치료사 계정은 therapistId 를 통해 기존 Therapist 정보(연락처·담당아동) 와 연결.

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  passwordHash String
  role         String   // 'OWNER' | 'ADMIN' | 'THERAPIST'
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  centerId     Int?
  center       Center?  @relation(fields: [centerId], references: [id])

  therapistId  Int?     @unique
  therapist    Therapist? @relation(fields: [therapistId], references: [id])

  sessions     AuthSession[]
  schedules    Schedule[] @relation("ScheduleCreatedBy")
  records      Record[]   @relation("RecordCreatedBy")
}

model AuthSession {
  id        Int      @id @default(autoincrement())
  token     String   @unique // 쿠키에 들어가는 무작위 문자열
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── 기존 도메인 ─────────────────────────────────────────────────────────

model Therapist {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  centerId  Int?
  center    Center?  @relation(fields: [centerId], references: [id])

  children  Child[]
  user      User?
}

model Child {
  id               Int       @id @default(autoincrement())
  name             String
  birthDate        String?   // YY.MM.DD 또는 YYYY-MM-DD 형식 자유
  serviceType      String    // "언어재활" 등
  mgmtNumber       String?   // 사회복지서비스 관리번호 (있으면)
  defaultSlot      String?   // "16:00~16:50"
  defaultDays      String?   // "3,4" — 콤마 구분 요일 (0=일)
  defaultUnit      Int       @default(65000) // 회당 단가
  defaultTarget    Int       @default(5)     // 월 목표 회기
  memo             String?
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  centerId         Int?
  center           Center?    @relation(fields: [centerId], references: [id])

  therapistId      Int?
  therapist        Therapist? @relation(fields: [therapistId], references: [id])

  schedules        Schedule[]
  records          Record[]
}

model Schedule {
  id          Int      @id @default(autoincrement())
  childId     Int
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  year        Int
  month       Int      // 1-12
  // 작성 시점 스냅샷 (나중에 아동·치료사 정보가 바뀌어도 보존)
  therapist   String
  serviceType String
  target      Int
  mgmtNumber  String?
  pvOrg       String
  pvTel       String?
  pvCharge    String?
  pvType      String
  costUnit    String   // "65,000" 형식 그대로
  costSelf    String   // "0"
  writeDate   String?  // "26.02.28" 등 자유 형식
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById Int?
  createdBy   User?    @relation("ScheduleCreatedBy", fields: [createdById], references: [id])

  sessions    ScheduleSession[]

  @@unique([childId, year, month])
}

model ScheduleSession {
  id         Int      @id @default(autoincrement())
  scheduleId Int
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  day        Int      // 1-31
  time       String   // "16:00~16:50"
  makeup     Boolean  @default(false)

  @@unique([scheduleId, day])
}

// ─── 기록지 ──────────────────────────────────────────────────────────────
// 작성한 기록지를 DB 에 저장. 다음에 다시 열어 편집·재출력 가능.

model Record {
  id          Int      @id @default(autoincrement())
  childId     Int
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  year        Int
  month       Int      // 1-12
  // 작성 시점 스냅샷
  org         String
  childName   String
  childBirth  String?
  opinion     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById Int?
  createdBy   User?    @relation("RecordCreatedBy", fields: [createdById], references: [id])

  sessions    RecordSession[]

  @@unique([childId, year, month])
}

model RecordSession {
  id          Int      @id @default(autoincrement())
  recordId    Int
  record      Record   @relation(fields: [recordId], references: [id], onDelete: Cascade)
  ordinal     Int      // 1부터 시작하는 회기 순서
  date        String?  // 'M/D' 헤더용
  startTime   String?
  endTime     String?
  voucher     String?  // 분
  extra       String?  // 분
  amount      String?  // 원 (포맷 포함)
  useDay      String?  // 제공일자 (일자만)
  payDay      String?  // 승인일자 (일자만)
  apprNumber  String?
  result      String?
  resultExtra String?

  @@unique([recordId, ordinal])
}
