// 바로일지 — 데이터 스키마 (SQLite, 로컬 개발용)
// Prisma 7

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── 멀티 센터 ──────────────────────────────────────────────────────────

model Center {
  id            Int      @id @default(autoincrement())
  name          String
  approvalCode  String   @unique
  address       String?
  phone         String?
  // 센터별 치료 영역. 콤마 구분 문자열. 센터가 추가/수정 가능.
  serviceTypes  String   @default("언어재활,놀이치료,감각통합치료")
  // 센터별 치료 시간대. 콤마 구분. 일정표·차단 시간 드롭다운에 사용.
  slots         String   @default("09:00~09:50,09:50~10:40,10:40~11:30,11:30~12:20,13:30~14:20,14:20~15:10,15:10~16:00,16:00~16:50,16:50~17:40,17:40~18:30,18:30~19:20")
  // 회당 기본 단가 (원). 아동 새로 등록할 때 자동 채움.
  defaultUnit   Int      @default(60000)
  // 기록지 출력 서식 (지역마다 양식이 달라 센터가 고른다). lib/record-forms.ts 의 key.
  recordForm    String   @default("standard")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         User[]
  therapists    Therapist[]
  children      Child[]
  invitations   Invitation[]
}

// 일회용 초대코드 — 원장이 만들고 한 사람에게 전달, 회원가입 시 사용되면 무효화.
model Invitation {
  id          Int       @id @default(autoincrement())
  token       String    @unique
  centerId    Int
  center      Center    @relation(fields: [centerId], references: [id], onDelete: Cascade)
  role        String    // 'THERAPIST' | 'ADMIN'
  name        String?
  email       String?
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  createdById Int?

  @@index([centerId])
}

// ─── 권한·로그인 ─────────────────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  passwordHash String
  role         String
  active       Boolean  @default(true)
  // 치료사 종류 — 보건복지부 발달재활서비스 제공인력 분류 + 기타
  therapistType String?
  // 바로툴(음성·학습 모듈) 요금제 — "trial"|"solo"|"pro"|"expired"
  plan         String   @default("trial")
  // 무료체험 만료. null = 베타(무기한 개방)
  trialEndsAt  DateTime?
  // 베타 참여자(평생 가격 잠금 대상)
  betaLockIn   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  centerId     Int?
  center       Center?  @relation(fields: [centerId], references: [id])

  therapistId  Int?     @unique
  therapist    Therapist? @relation(fields: [therapistId], references: [id])

  sessions     AuthSession[]
  schedules    Schedule[] @relation("ScheduleCreatedBy")
  records      Record[]   @relation("RecordCreatedBy")
  passwordResets PasswordReset[]
  recordForms    RecordForm[]
  supportRecords SupportRecord[]
  programs       Program[]
  toolChildren   ToolChild[]
}

model PasswordReset {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model AuthSession {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── 도메인 ────────────────────────────────────────────────────────────

model Therapist {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  centerId  Int?
  center    Center?  @relation(fields: [centerId], references: [id])

  services  ChildService[]
  user      User?
  blocks    TherapistBlock[]
}

model TherapistBlock {
  id          Int      @id @default(autoincrement())
  therapistId Int
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  dayOfWeek   Int
  startTime   String
  endTime     String
  reason      String?
  createdAt   DateTime @default(now())

  @@index([therapistId])
}

// Child = 사람(아동). 한 아동은 여러 서비스(=ChildService)를 받을 수 있음.
model Child {
  id         Int       @id @default(autoincrement())
  name       String
  birthDate  String?
  mgmtNumber String?
  memo       String?
  active     Boolean   @default(true)
  waiting    Boolean   @default(false) // 대기 명단 여부 (상담 예정 등)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  centerId   Int?
  center     Center?   @relation(fields: [centerId], references: [id])

  services   ChildService[]
  toolSessions ToolSession[]
}

// 바로툴(음성·학습 모듈) 대상자별 측정 세션 — 지속 모니터링용.
model ToolSession {
  id           Int        @id @default(autoincrement())
  childId      Int?
  child        Child?     @relation(fields: [childId], references: [id], onDelete: Cascade)
  toolChildId  Int?
  toolChild    ToolChild? @relation(fields: [toolChildId], references: [id], onDelete: Cascade)
  centerId     Int?
  therapistId  Int?
  module       String
  metrics      String
  note         String?
  createdAt    DateTime   @default(now())

  @@index([childId, module])
  @@index([toolChildId, module])
  @@index([centerId])
}

// 업로드한 센터 기록지/일정표 양식 — 프리랜서는 센터마다 달라 사용자별 다수 저장.
model RecordForm {
  id          Int      @id @default(autoincrement())
  ownerUserId Int
  ownerUser   User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  kind        String
  name        String
  template    Bytes
  spec        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerUserId, kind])
}

// 기타지원사업 작성 저장본 — 한 번 작성한 아동을 불러오기/수정.
model SupportRecord {
  id          Int      @id @default(autoincrement())
  ownerUserId Int
  ownerUser   User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  program     String   // 지원사업 키 (예: "maeummoa", "custom")
  programId   Int?     // 커스텀 사업(Program.id) — program="custom" 일 때 세팅
  programRel  Program? @relation(fields: [programId], references: [id], onDelete: SetNull)
  toolChildId Int?     // 바로툴 대상자 연결(선택)
  toolChild   ToolChild? @relation(fields: [toolChildId], references: [id], onDelete: SetNull)
  student     String   // 아동 이름 (목록 표시용)
  payload     String   // 폼 전체 데이터(JSON: 헤더 + 회기)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerUserId, program])
  @@index([programId])
}

// 치료사가 직접 만든 기타지원사업 — 기록지 양식을 업로드해 출력.
model Program {
  id           Int      @id @default(autoincrement())
  ownerId      Int
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name         String
  formTemplate Bytes?   // 업로드한 빈 .hwpx 원본
  formSpec     String?  // 자동매핑 결과 JSON
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  supportRecords SupportRecord[]

  @@index([ownerId])
}

// 치료사 개인 대상자 명단(바로툴용) — ChildService 아동과 별개로 간편 등록.
model ToolChild {
  id        Int      @id @default(autoincrement())
  ownerId   Int
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  memo      String?
  createdAt DateTime @default(now())

  toolSessions   ToolSession[]
  supportRecords SupportRecord[]

  @@index([ownerId])
}

// ChildService = 한 아동이 받는 한 서비스. (아동 × 서비스 종류 × 치료사)
// 일정표·기록지는 이 단위로 작성.
model ChildService {
  id            Int       @id @default(autoincrement())
  childId       Int
  child         Child     @relation(fields: [childId], references: [id], onDelete: Cascade)

  therapistId   Int?
  therapist     Therapist? @relation(fields: [therapistId], references: [id])

  serviceType   String    // "언어재활" 등 — Center.serviceTypes 중 하나
  defaultSlot   String?
  defaultDays   String?
  // 요일별 시간대 오버라이드. "1=09:00~09:50,3=10:00~10:50" 형식. 비면 모든 요일이 defaultSlot.
  daySlots      String?
  // 서비스 제공자명(제공기관명). 일정표에서 바꾸면 저장돼 다음 달부터 유지(프리랜서 다(多)센터 대응).
  org           String?
  defaultUnit   Int       @default(65000)
  defaultTarget Int       @default(5)
  // 월 본인부담금 (원). 부모님이 매월 내는 금액. 일정표 자동 채움용.
  monthlyCopay  Int?

  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  schedules     Schedule[]
  records       Record[]

  @@index([childId])
  @@index([therapistId])
}

model Schedule {
  id             Int      @id @default(autoincrement())
  childServiceId Int
  childService   ChildService @relation(fields: [childServiceId], references: [id], onDelete: Cascade)
  year           Int
  month          Int
  therapist      String
  serviceType    String
  target         Int
  mgmtNumber     String?
  pvOrg          String
  pvTel          String?
  pvCharge       String?
  pvType         String
  costUnit       String
  costSelf       String
  writeDate      String?
  formId         Int?     // 저장 시 선택한 업로드 양식(RecordForm.id) — 일괄 출력에 사용
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdById    Int?
  createdBy      User?    @relation("ScheduleCreatedBy", fields: [createdById], references: [id])

  sessions       ScheduleSession[]

  @@unique([childServiceId, year, month])
}

model ScheduleSession {
  id         Int      @id @default(autoincrement())
  scheduleId Int
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  day        Int
  time       String
  makeup     Boolean  @default(false)

  @@unique([scheduleId, day])
}

// ─── 기록지 ──────────────────────────────────────────────────────────────

model Record {
  id             Int      @id @default(autoincrement())
  childServiceId Int
  childService   ChildService @relation(fields: [childServiceId], references: [id], onDelete: Cascade)
  year           Int
  month          Int
  org            String
  childName      String
  childBirth     String?
  opinion        String?
  formId         Int?     // 저장 시 선택한 업로드 양식(RecordForm.id) — 일괄 출력에 사용
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdById    Int?
  createdBy      User?    @relation("RecordCreatedBy", fields: [createdById], references: [id])

  sessions       RecordSession[]

  @@unique([childServiceId, year, month])
}

model RecordSession {
  id          Int      @id @default(autoincrement())
  recordId    Int
  record      Record   @relation(fields: [recordId], references: [id], onDelete: Cascade)
  ordinal     Int
  date        String?
  startTime   String?
  endTime     String?
  voucher     String?
  extra       String?
  amount      String?
  useDay      String?
  payDay      String?
  apprNumber  String?
  result      String?
  resultExtra String?
  status      String?

  @@unique([recordId, ordinal])
}
