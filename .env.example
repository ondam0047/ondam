# 로컬 개발 (SQLite) — 기본값이라 안 적어도 됨
# DATABASE_URL="file:./prisma/dev.db"

# 운영 (PostgreSQL on NCP)
# DATABASE_URL="postgresql://baroilji:비밀번호@localhost:5432/baroilji"

# Next.js
NODE_ENV="production"

# ── 베타 잠금 ──
# 설정 시 가입 화면에 초대코드 입력 필수. 비우면 누구나 가입 가능 (정식 출시 모드).
# BETA_ACCESS_CODE="ABCD1234"

# 베타 운영자 이메일 — 이 이메일로 로그인한 사람만 /admin/beta 접근 가능
# BETA_ADMIN_EMAIL="yj2000102@gmail.com"

# ── 도움말 사용법 영상 (NCP Object Storage 공개 버킷 베이스 URL) ──
# 비우면 도움말에 영상이 표시되지 않음(텍스트만). 버킷 업로드 후 설정.
# 슬러그(guide-01-...) 앞까지의 경로만. 예: .../baroilji-guide/guide
# NEXT_PUBLIC_GUIDE_MEDIA_BASE="https://kr.object.ncloudstorage.com/baroilji-guide/guide"
