# 로컬 개발 (SQLite) — 기본값이라 안 적어도 됨
# DATABASE_URL="file:./prisma/dev.db"

# 운영 (PostgreSQL on NCP)
# DATABASE_URL="postgresql://baroilji:비밀번호@localhost:5432/baroilji"

# Next.js
NODE_ENV="production"

# ── 베타 잠금 ──
# 설정 시 가입 화면에 초대코드 입력 필수. 비우면 누구나 가입 가능 (정식 출시 모드).
# BETA_ACCESS_CODE="ABCD1234"

# 베타 운영자 이메일 — 이 이메일로 로그인한 사람만 /admin/beta 접근 가능
# BETA_ADMIN_EMAIL="yj2000102@gmail.com"

# ── 도움말 사용법 영상 (NCP Object Storage 공개 버킷 베이스 URL) ──
# 비우면 도움말에 영상이 표시되지 않음(텍스트만). 버킷 업로드 후 설정.
# 슬러그(guide-01-...) 앞까지의 경로만. 예: .../baroilji-guide/guide
# NEXT_PUBLIC_GUIDE_MEDIA_BASE="https://kr.object.ncloudstorage.com/baroilji-guide/guide"

# ── 비밀번호 재설정 이메일 (SMTP — Resend/SendGrid/NCP Outbound Mailer 등) ──
# 미설정 시 '비밀번호 찾기'는 동작하나 메일이 안 나감(서버 로그만). 아래 채우면 자동 발송.
# APP_URL="https://baroilji.com"            # 재설정 링크 베이스
# SMTP_HOST="smtp.resend.com"
# SMTP_PORT="587"                            # 465면 SMTP_SECURE=true
# SMTP_SECURE="false"
# SMTP_USER="resend"                         # 제공자별 사용자명 (Resend는 'resend')
# SMTP_PASS="re_xxxxxxxx"                     # 제공자 SMTP 비밀번호/API키
# MAIL_FROM="바로일지 <no-reply@baroilji.com>"  # 인증된 발신주소

# ── DB 오프사이트 백업 (NCP Object Storage 비공개 버킷) ──
# BACKUP_BUCKET="baroilji-backup"
# AWS_ACCESS_KEY_ID="ncp_iam_..."
# AWS_SECRET_ACCESS_KEY="..."
# AWS_DEFAULT_REGION="kr-standard"
