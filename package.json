    "better-sqlite3": "^12.10.0",
    "docx": "^9.7.1",
    "jszip": "^3.10.1",
    "next": "16.2.6",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
