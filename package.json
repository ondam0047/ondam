    "db:export:sqlite": "node --experimental-strip-types scripts/export-sqlite.ts",
    "db:import:postgres": "PRISMA_SCHEMA=postgres node --experimental-strip-types scripts/import-postgres.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
